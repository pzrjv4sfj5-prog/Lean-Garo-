{
  "version": 2,
  "name": "lean-garo-translator",
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/static-build"
    }
  ],
  "outputDirectory": "dist",
  "env": {
    "VITE_GEMINI_API_KEY": "@vite_gemini_api_key"
  },
  "routes": [
    {
      "handle": "filesystem"
    },
    {
      "src": "/.*",
      "dest": "/index.html"
    }
  ]
}

